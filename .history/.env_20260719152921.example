# Supabase project credentials (client-safe — anon key only).
# Copy this file to `.env` and fill in your values.
VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-public-key

# Domain used to synthesize staff login emails from usernames.
# Must match the domain used when creating staff accounts in the Edge Function.
VITE_STAFF_EMAIL_DOMAIN=pppoe.local
